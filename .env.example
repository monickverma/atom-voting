# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-long-random-secret-key
APP_DEBUG=true

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://atomvoting:password@localhost:5432/atomvoting

# ─── Redis Cache ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth (optional external provider) ───────────────────────────────────────
AUTH_PROVIDER_URL=
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
